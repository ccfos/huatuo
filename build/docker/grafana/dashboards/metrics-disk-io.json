        "includeAll": false,
        "multi": false
      },
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "huatuo-bamai-prom"
        },
        "query": "label_values(huatuo_bamai_disk_io_disk_iowait_ratio{region=\"$region\"}, host)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
